# 所有变量都有默认值，开发环境通常无需额外 .env 文件
# 如需自定义配置：本地直接运行时请导出这些环境变量；使用 Docker Compose 时可在仓库根目录创建 .env 文件

# API 服务监听端口（默认 3001）
PORT=3001

# SQLite 数据库文件路径（默认 apps/api/data/dev.sqlite）
DATABASE_PATH=apps/api/data/dev.sqlite

# QQ Music API 代理地址（默认使用公共服务）
QQMUSIC_BASE_URL=https://api.ygking.top

# 允许跨域的前端地址（默认 Vite 开发服务器地址）
CORS_ORIGIN=http://127.0.0.1:5173

# Session 签名密钥（生产环境必须设置，建议 32 位以上随机字符串）
# 生成命令：openssl rand -base64 32
SESSION_SECRET=

# 是否要求 HTTPS 才能发送 Cookie（生产环境使用 HTTPS 时建议设为 true）
SECURE_COOKIE=false

## 是否信任前置反向代理传入的 X-Forwarded-* 头（Docker/Nginx 反代部署建议为 true）
TRUST_PROXY=false

# Docker Compose 对外访问地址（默认 http://localhost:8080）
PUBLIC_ORIGIN=http://localhost:8080

# Docker Compose Web 容器映射到宿主机的端口（默认 8080）
WEB_PORT=8080
